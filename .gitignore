# Ignore Python cache and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.log

# Ignore virtual environment
venv/
env/
.venv/

# Ignore model and generated files
*.pkl
*.h5
*.onnx
*.joblib
*.pt
*.ckpt
*.tflite
.cache/

# Ignore dynamically generated feedback data
feedback_data.csv

# Ignore environment variables and credentials
.env
*.secret
config.json
credentials.json

# Ignore logs and temporary files
*.log
logs/
debug.log
nohup.out
*.tmp
*.swp

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore FastAPI static and cache files
staticfiles/
mediafiles/

# Ignore frontend build artifacts (if any enhancements)
node_modules/
dist/
build/
npm-debug.log
yarn-error.log

# Ignore Docker and Kubernetes build artifacts
docker-compose.override.yml
*.dockerfile
*.tar
*.img
*.bin
docker-*
.kubernetes/

# Ignore VS Code, PyCharm, and IDE-specific files
.vscode/
.idea/
*.iml

# Ignore system files
.DS_Store
Thumbs.db